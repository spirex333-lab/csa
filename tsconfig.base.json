{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@chatbot-builder/be-nest-module": ["tools/be-nest-module/src/index.ts"],
      "@chatbot-builder/be-nest-module/*": ["tools/be-nest-module/src/*"],
      "@webapp/components/*": ["apps/webapp/src/components/*"],
      "@workspace/auth": ["libs/backend/auth/src/index.ts"],
      "@workspace/auth/*": ["libs/backend/auth/src/*"],
      "@workspace/be-commons": ["libs/backend/be-commons/src/index.ts"],
      "@workspace/be-commons/*": ["libs/backend/be-commons/src/*"],
      "@workspace/change-now": ["libs/backend/change-now/src/index.ts"],
      "@workspace/change-now/*": ["libs/backend/change-now/src/*"],
      "@workspace/chat-groups": ["libs/backend/chat-groups/src"],
      "@workspace/chat-groups/*": ["libs/backend/chat-groups/utils/src/*"],
      "@workspace/chats": ["libs/backend/chats/src"],
      "@workspace/chats/*": ["libs/backend/chats/utils/src/*"],
      "@workspace/commons/*": ["libs/commons/src/*"],
      "@workspace/commons/server": ["libs/commons/src/server.ts"],
      "@workspace/commons/workflow": ["libs/commons/src/workflow/index.ts"],
      "@workspace/config": ["libs/backend/config/src"],
      "@workspace/config/*": ["libs/backend/config/utils/src/*"],
      "@workspace/crawler": ["libs/backend/crawler/src/index.ts"],
      "@workspace/crawler/*": ["libs/backend/crawler/src/*"],
      "@workspace/eds": ["libs/eds/src/index.ts"],
      "@workspace/eds/*": ["libs/eds/src/*"],
      "@workspace/execution": ["libs/backend/execution/src/index.ts"],
      "@workspace/execution/*": ["libs/backend/execution/src/*"],
      "@workspace/ffio": ["libs/backend/ffio/src/index.ts"],
      "@workspace/ffio/*": ["libs/backend/ffio/src/*"],
      "@workspace/files-api/*": ["libs/backend/files/src/*"],
      "@workspace/icons/*": ["libs/icons/src/*"],
      "@workspace/icons/server": ["libs/icons/src/server.ts"],
      "@workspace/ipualog": ["libs/backend/ipualog/src/index.ts"],
      "@workspace/ipualog/*": ["libs/backend/ipualog/src/*"],
      "@workspace/mailer": ["libs/backend/mailer/src"],
      "@workspace/mailer/*": ["libs/backend/mailer/src/*"],
      "@workspace/matrix": ["libs/backend/matrix/src/index.ts"],
      "@workspace/matrix/*": ["libs/backend/matrix/src/*"],
      "@workspace/mysql-db": ["libs/backend/mysql-db/src/index.ts"],
      "@workspace/mysql-db/*": ["libs/backend/mysql-db/src/*"],
      "@workspace/orders": ["libs/backend/orders/src/index.ts"],
      "@workspace/orders/*": ["libs/backend/orders/src/*"],
      "@workspace/queue": ["libs/backend/queue/src/index.ts"],
      "@workspace/queue/*": ["libs/backend/queue/src/*"],
      "@workspace/socket-io": ["libs/backend/socket-io/src/index.ts"],
      "@workspace/test": ["libs/backend/test/src/index.ts"],
      "@workspace/test/*": ["libs/backend/test/src/*"],
      "@workspace/trigger": ["libs/backend/trigger/src/index.ts"],
      "@workspace/trigger/*": ["libs/backend/trigger/src/*"],
      "@workspace/ui": ["libs/ui/src/index.ts"],
      "@workspace/ui/*": ["libs/ui/src/*"],
      "@workspace/utils": ["libs/utils/src/index.ts"],
      "@workspace/utils/*": ["libs/utils/src/*"],
      "@workspace/worker": ["libs/backend/worker/src/index.ts"],
      "@workspace/worker/*": ["libs/backend/worker/src/*"],
      "@workspace/workflow": ["libs/backend/workflow/src/index.ts"],
      "@workspace/workflow/*": ["libs/backend/workflow/src/*"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
