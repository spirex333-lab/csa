# API runtime
CB_HOST=localhost
CB_PORT=4001
CB_API_PREFIX=api
# JSON array string expected
CB_CORS=["*"]

# Auth
CB_MASTER_KEY=change-me
JWT_SECRET=change-me
NEXTAUTH_SECRET=change-me

# File uploads
ENV_FILES_UPLOAD_PATH=uploads

# OpenAI (used by generated-files controller)
OPENAI_API_KEY=

# Database (TypeORM runtime)
POSTGRES_DB_HOST=localhost
POSTGRES_DB_PORT=5432
POSTGRES_DB_USERNAME=postgres
POSTGRES_DB_PASSWORD=postgres
POSTGRES_DB_NAME=chatbotbase

# Database (migrations/data-source)
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=chatbotbase

# Matrix integration
MATRIX_SERVER_URL=http://localhost:8008
MATRIX_SERVER_DOMAIN=my.matrix.host
MATRIX_SERVER_DOMAIN_NAME=my.matrix.host
MATRIX_SERVER_SHARED_SECRET=
MATRIX_SERVER_ADMIN_API_KEY=
MATRIX_SERVER_ADMIN_USER=admin_bot

# Optional external services
IP_INFO_API=
GOOGLE_CLIENT_EMAIL=
GOOGLE_CLIENT_PRIV_KEY=
GOOGLE_SHEET_ID=

# Crawler
CRAWLER_REDIS_URL=redis://127.0.0.1:6379/0
CRAWLER_REDIS_QUEUE_KEY=crawler:requests
CRAWLER_TIMEOUT_MS=30000
CRAWLER_MAX_PAGES_PER_SITE=250
CRAWLER_MIN_WORKERS=2
