{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../../dist/out-tsc",
    "declaration": true,
    "types": ["node"],
    "target": "es2021",
    "strictNullChecks": true,
    "noImplicitAny": true,
    "strictBindCallApply": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src/**/*.ts", "../../commons/src/dtos/auth/local-login.dto.ts", "../../commons/src/dtos/auth/local-register.dto.ts", "../be-commons/src/entities/api-key.entity.ts", "../be-commons/src/entities/role.entity.ts", "../be-commons/src/entities/user.entity.ts", "../be-commons/src/entities/authenticated.entity.ts"],
  "exclude": ["jest.config.ts", "src/**/*.spec.ts", "src/**/*.test.ts"]
}
